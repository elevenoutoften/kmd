{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-v2-schema/main/tauri.schema.json",
  "productName": "kmd",
  "version": "0.1.0",
  "identifier": "io.github.elevenoutoften.kmd",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "kmd",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'none'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'; connect-src https://github.com https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "fileAssociations": [
      {
        "ext": ["md"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": ["markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": ["design.md"],
        "mimeType": "text/markdown",
        "description": "kmd design document",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwMzI5NzA2NDIxOUUyQTIKUldTaTRobENCcGN5NENOQ2ZaOEMzTE12YWpLYktXMlNSczg4S2FTbEdpMmt3K2MvM2hCUUI1bW8K",
      "endpoints": [
        "https://github.com/elevenoutoften/kmd/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
