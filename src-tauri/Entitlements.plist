<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Enable App Sandbox (required for App Store, good practice) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Allow reading files that the user selects via Open dialog
         or that macOS delivers via file association (Finder double-click) -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>

    <!-- Allow writing to files the user selects (needed for future save features) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>