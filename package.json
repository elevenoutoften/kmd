{
  "name": "kmd",
  "version": "0.2.0",
  "description": "Kawaii MD reader: a local-first desktop Markdown reader with first-class DESIGN.md support.",
  "license": "MIT",
  "author": "kmd contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elevenoutoften/kmd.git"
  },
  "bugs": {
    "url": "https://github.com/elevenoutoften/kmd/issues"
  },
  "homepage": "https://github.com/elevenoutoften/kmd#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "icons:sync": "node scripts/sync-icons.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:portable": "node scripts/tauri-build.mjs --no-bundle",
    "tauri:bundle:app": "node scripts/tauri-build.mjs --bundles app",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-alerts": "^0.1.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.5"
  }
